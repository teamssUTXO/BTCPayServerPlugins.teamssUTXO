@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.teamssUTXO.Plugins.UptimeChecker
@model BTCPayServer.teamssUTXO.Plugins.UptimeChecker.ViewModels.UptimeCheckHistoryViewModel
@{
    Layout = "_Layout";
    ViewData.SetActivePage(PluginNavPages.UptimeChecker, "Check History");
}

<div class="sticky-header d-flex flex-wrap align-items-center justify-content-between gap-2">
    <h2 class="mb-0">@ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-secondary">Back to checks</a>
</div>

<partial name="_StatusMessage" />

<div class="row mt-4">
    <div class="col-12 col-md-8 col-lg-6">
        <h4 class="mb-3">History settings</h4>
        <form method="post" asp-action="History">
            <div class="mb-3">
                <div class="form-check form-switch">
                    <input asp-for="EnableHistory" class="form-check-input" type="checkbox" id="enableHistoryToggle" />
                    <label asp-for="EnableHistory" class="form-check-label" for="enableHistoryToggle">
                        Record check history
                    </label>
                </div>
                <small class="text-muted">When enabled, every check result is stored in the database.</small>
            </div>
            <div id="retentionSection" class="mb-3" style="@(Model.EnableHistory ? "" : "display:none")">
                <label asp-for="RetentionDays" class="form-label"></label>
                <input asp-for="RetentionDays" class="form-control w-auto" type="number" min="1" max="365" style="max-width:120px" />
                <span asp-validation-for="RetentionDays" class="text-danger small"></span>
                <small class="text-muted d-block mt-1">Entries older than this many days are deleted automatically (1–365).</small>
            </div>
            <button type="submit" class="btn btn-primary">Save settings</button>
        </form>
    </div>
</div>

<hr class="my-4" />

@if (!Model.EnableHistory)
{
    <p class="text-muted">History recording is disabled. Enable it above to start logging check results.</p>
}
else if (!Model.Entries.Any())
{
    <p class="text-muted">No history entries yet. Results will appear here after the next scheduled check run.</p>
}
else
{
    <h4 class="mb-3">Recent check runs</h4>
    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead>
                <tr>
                    <th>URL</th>
                    <th>Status</th>
                    <th class="d-none d-sm-table-cell">HTTP code</th>
                    <th class="d-none d-md-table-cell">Response time</th>
                    <th>Checked at</th>
                    <th class="d-none d-lg-table-cell">Error</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.Entries)
                {
                    <tr>
                        <td style="max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            <a href="@entry.Url" target="_blank" rel="noopener" title="@entry.Url">@entry.Url</a>
                        </td>
                        <td>
                            @if (entry.IsUp)
                            {
                                <span class="badge bg-success">UP</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">DOWN</span>
                            }
                        </td>
                        <td class="d-none d-sm-table-cell">
                            @if (entry.HttpStatusCode.HasValue)
                            {
                                if (entry.HttpStatusCode is >= 200 and < 400)
                                {
                                    <span class="text-success">@entry.HttpStatusCode</span>
                                }
                                else
                                {
                                    <span class="text-danger">@entry.HttpStatusCode</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="d-none d-md-table-cell">@entry.CheckDurationMs ms</td>
                        <td>
                            <span title="@entry.CheckedAt.ToString("u")">@entry.CheckedAt.ToLocalTime().ToString("g")</span>
                        </td>
                        <td class="d-none d-lg-table-cell">
                            @if (!string.IsNullOrWhiteSpace(entry.ErrorMessage))
                            {
                                <small class="text-muted">@entry.ErrorMessage</small>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<script>
    document.getElementById('enableHistoryToggle').addEventListener('change', function () {
        document.getElementById('retentionSection').style.display = this.checked ? '' : 'none';
    });
</script>
