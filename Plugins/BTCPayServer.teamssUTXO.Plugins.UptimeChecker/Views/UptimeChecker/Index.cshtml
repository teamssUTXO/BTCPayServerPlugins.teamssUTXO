@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.teamssUTXO.Plugins.UptimeChecker
@using BTCPayServer.Abstractions.Models
@model BTCPayServer.teamssUTXO.Plugins.UptimeChecker.ViewModels.UptimeCheckListViewModel
@{
    Layout = "_Layout";
    ViewData.SetActivePage(PluginNavPages.UptimeChecker, "Uptime Checker");
}

<div class="sticky-header d-flex align-items-center justify-content-between">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Create" class="btn btn-primary">Add check</a>
</div>

<partial name="_StatusMessage" />

@if (!Model.Checks.Any())
{
    <p class="text-muted mt-4">No checks configured yet. Click <strong>Add check</strong> to get started.</p>
}
else
{
    <table class="table table-hover mt-4">
        <thead>
            <tr>
                <th>URL</th>
                <th>Interval</th>
                <th>Status</th>
                <th>HTTP Code</th>
                <th>Last checked</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var check in Model.Checks)
            {
                var result = check.LastResult;
                var inactiveClass = !check.IsEnabled ? "text-muted opacity-50" : null;
                <tr>
                    <td class="@inactiveClass">
                        <a href="@check.Url" target="_blank" rel="noopener">@check.Url</a>
                    </td>
                    <td class="@inactiveClass">@check.IntervalMinutes min</td>
                    <td class="@inactiveClass">
                        @if (result is null)
                        {
                            <span class="badge bg-secondary">Pending</span>
                        }
                        else if (result.IsUp)
                        {
                            <span class="badge bg-success">UP</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">DOWN</span>
                            @if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
                            {
                                <small class="text-muted ms-1">@result.ErrorMessage</small>
                            }
                        }
                    </td>
                    <td class="@inactiveClass">
                        @if (result is not null)
                        {
                            if (result.HttpStatusCode is >= 200 and <= 399)
                            {
                                <span class="text-success">@result.HttpStatusCode</span>
                            } else
                            {
                                <span class="text-danger">@result.HttpStatusCode</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="@inactiveClass">
                        @if (result is not null)
                        {
                            <span title="@result.CheckedAt.ToString("u")">@result.CheckedAt.ToLocalTime().ToString("g")</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td class="@inactiveClass">
                        @if (check.IsEnabled)
                        {
                            <span class="text-success">Yes</span>
                        }
                        else
                        {
                            <span class="text-muted">No</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@check.Id" class="btn btn-sm btn-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@check.Id"
                           class="btn btn-sm btn-danger"
                           data-bs-toggle="modal"
                           data-bs-target="#ConfirmModal"
                           data-title="Delete check"
                           data-description="The check for <strong>@Html.Encode(check.Url)</strong> will be permanently deleted."
                           data-confirm="Delete">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<partial name="_Confirm" model="@(new ConfirmModel("Delete check", "This check will be permanently deleted.", "Delete"))" />
